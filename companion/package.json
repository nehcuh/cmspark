{
  "name": "cmspark-agent",
  "version": "0.2.0",
  "description": "Local companion for CMspark Browser Agent — manages LLM calls, skills, threads, and operation history. Now with cross-platform system tray.",
  "bin": {
    "cmspark-agent": "./dist/index.js"
  },
  "scripts": {
    "prebuild": "node scripts/generate-tray-icons.mjs",
    "build": "tsc && node -e \"process.platform!=='win32'&&require('fs').chmodSync('dist/index.js',0o755)\"",
    "test": "node -e \"require('fs').rmSync('.test-dist',{recursive:true,force:true})\" && tsc -p tsconfig.test.json && node --test $(find .test-dist/tests -name '*.test.js' -not -name '_*' -not -name 'settings-web.test.js') && node --test .test-dist/tests/settings-web.test.js",
    "start": "node dist/index.js start",
    "dev": "tsx src/index.ts start",
    "daemon:start": "node dist/index.js daemon start --daemonize",
    "daemon:stop": "node dist/index.js daemon stop",
    "daemon:status": "node dist/index.js daemon status",
    "tray": "node dist/index.js tray",
    "tray:status": "node dist/index.js tray status",
    "tray:rebuild": "node dist/index.js tray rebuild",
    "menu-bar": "node dist/index.js menu-bar",
    "postinstall": "node ../scripts/verify-systray2.js && node ../scripts/build-swift-tray.js",
    "bundle:exe": "npx esbuild dist/index.js --bundle --platform=node --target=node22 --external:systray2 --external:canvas --external:pdfjs-dist --external:@modelcontextprotocol/sdk --outfile=dist/cmspark-agent.js",
    "build:exe": "npm run build && npm run bundle:exe"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@types/dompurify": "^3.0.5",
    "@types/js-yaml": "^4.0.9",
    "adm-zip": "^0.5.17",
    "dompurify": "^3.4.8",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.2.0",
    "node-notifier": "^10.0.1",
    "officeparser": "^7.2.3",
    "openai": "^4.52.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.0.0",
    "sql.js": "^1.14.1",
    "systray2": "^2.1.4",
    "ws": "^8.17.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  }
}
