{
  "name": "cmspark-browser-agent",
  "displayName": "CMspark Browser Agent",
  "version": "0.1.0",
  "description": "AI-powered browser agent — read, operate tabs, use cookies, configure LLM, support skills",
  "author": "cmspark",
  "scripts": {
    "dev": "plasmo dev",
    "postinstall": "node scripts/patch-vfile.mjs",
    "test": "node -e \"require('fs').rmSync('.test-dist',{recursive:true,force:true})\" && tsc -p tsconfig.test.json && node --test .test-dist/tests/**/*.test.js",
    "prebuild": "node scripts/generate-icons.mjs",
    "build": "tsc --noEmit && plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "dompurify": "^3.4.8",
    "katex": "^0.16.47",
    "marked": "^18.0.4",
    "marked-katex-extension": "^5.1.10",
    "mermaid": "^11.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "plasmo": "^0.90.5",
    "svgo": "^3.3.3",
    "typescript": "^5.4.5"
  },
  "alias": {
    "@mermaid-js/parser": "@mermaid-js/parser/dist/mermaid-parser.core.mjs"
  },
  "manifest": {    "host_permissions": [
      "<all_urls>",
      "http://127.0.0.1/*",
      "http://localhost/*"
    ],
    "permissions": [
      "debugger",
      "tabs",
      "activeTab",
      "storage",
      "alarms",
      "sidePanel",
      "cookies",
      "scripting",
      "notifications"
    ]
  }
}
