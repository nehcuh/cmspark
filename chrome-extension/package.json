{
  "name": "cmspark-browser-agent",
  "displayName": "CMspark Browser Agent",
  "version": "0.1.0",
  "description": "AI-powered browser agent — read, operate tabs, use cookies, configure LLM, support skills",
  "author": "cmspark",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build || (node scripts/generate-icons.mjs && plasmo build)",
    "package": "plasmo package"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "plasmo": "^0.90.5",
    "typescript": "^5.4.5"
  },
  "manifest": {
    "host_permissions": [
      "<all_urls>",
      "http://127.0.0.1/*",
      "http://localhost/*"
    ],
    "permissions": [
      "debugger",
      "tabs",
      "activeTab",
      "storage",
      "alarms",
      "sidePanel",
      "cookies",
      "scripting",
      "notifications"
    ]
  }
}
