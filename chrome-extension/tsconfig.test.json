{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "rootDir": ".",
    "outDir": ".test-dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "types": ["chrome", "react", "react-dom"]
  },
  "include": [
    "src/sidepanel/types.ts",
    "src/sidepanel/store/agentStore.tsx",
    "src/sidepanel/hooks/useWebSocket.ts",
    "src/background/page-sanitizer.ts",
    "src/background/image-extract-utils.ts",
    "src/background/dangerous-apis.ts",
    "src/notebooklm/extractor.ts",
    "src/notebooklm/markdown-builder.ts",
    "src/notebooklm/types.ts",
    "src/notebooklm/selectors.ts",
    "src/notebooklm/notebook-api.ts",
    "src/notebooklm/dom-automation.ts",
    "src/notebooklm/ai-chat-extractor.ts",
    "src/notebooklm/page-link-extractor.ts",
    "src/notebooklm/rss-parser.ts",
    "src/notebooklm/youtube-api.ts",
    "src/notebooklm/cdp-fetch-interceptor.ts",
    "src/notebooklm/rpc-client.ts",
    "src/sidepanel/hooks/useModalDialog.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "build", ".plasmo", ".test-dist"]
}
